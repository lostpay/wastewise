# Point at the FastAPI backend (AMD Cloud / local). If unset, the app runs in demo mode.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Google Maps JavaScript API key. Enables the map + Places autocomplete on the
# Setup screen. If unset, the Setup screen falls back to a plain "lat,lon" input.
# Get one at https://console.cloud.google.com — enable Maps JavaScript API,
# Places API, and Geocoding API on the same key.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Optional Cloud-configured Map ID (Maps > Map Management). Required for the
# vector map + AdvancedMarker; if unset, the picker uses the classic marker.
NEXT_PUBLIC_GOOGLE_MAP_ID=
